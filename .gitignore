# Build directories
build

# Firmware configuration
sdkconfig*
!sdkconfig.defaults

# Doesn't publish ESP IDF components.
# Automatically downloaded on build.
managed_components

# Project is build using ESP IDF Vscode extension.
# But ignore, as the repo doesn't depend on it.
.vscode

# Ignore custom configuration.
usb-output/main/config_custom.h

